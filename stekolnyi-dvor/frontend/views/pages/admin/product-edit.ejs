<section class="admin-page">
    <div class="container">
        <h1><%= isEdit ? 'Редактирование товара' : 'Добавление товара' %></h1>
        
        <div class="admin-nav">
            <a href="/admin">Дашборд</a>
            <a href="/admin/products" class="active">Товары</a>
            <a href="/admin/categories">Категории</a>
            <a href="/admin/orders">Заказы</a>
        </div>
        
        <form action="<%= isEdit ? '/admin/products/edit/' + product.id : '/admin/products/add' %>" 
              method="POST" 
              enctype="multipart/form-data" 
              class="admin-form">
            
            <div class="form-group">
                <label for="name">Название *</label>
                <input type="text" id="name" name="name" required value="<%= product ? product.name : '' %>">
            </div>
            
            <div class="form-group">
                <label for="description">Описание</label>
                <textarea id="description" name="description" rows="5"><%= product ? product.description : '' %></textarea>
            </div>
            
            <div class="form-group">
                <label for="price">Цена *</label>
                <input type="number" id="price" name="price" step="0.01" required value="<%= product ? product.price : '' %>">
            </div>
            
            <div class="form-group">
                <label for="category_id">Категория</label>
                <select id="category_id" name="category_id">
                    <option value="">Без категории</option>
                    <% categories.forEach(category => { %>
                        <option value="<%= category.id %>" <%= product && product.category_id === category.id ? 'selected' : '' %>>
                            <%= category.name %>
                        </option>
                    <% }) %>
                </select>
            </div>
            
            <div class="form-group">
                <label for="volume">Объем</label>
                <input type="text" id="volume" name="volume" value="<%= product ? product.volume : '' %>">
            </div>
            
            <div class="form-group">
                <label>
                    <input type="checkbox" name="in_stock" value="1" <%= product && product.in_stock == 1 ? 'checked' : '' %>> 
                    В наличии
                </label>
                <small>Если снять галочку, товар не будет отображаться на сайте</small>
            </div>
            
            <div class="form-group">
                <label>Фото товара</label>
                
                <!-- Текущие изображения -->
                <% if (product && product.images) { 
                    let images = [];
                    try {
                        images = JSON.parse(product.images || '[]');
                    } catch(e) {
                        images = [];
                    }
                    if (images.length > 0) { %>
                        <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px;">
                            <% images.forEach((img, index) => { %>
                                <div style="position: relative; display: inline-block;" data-index="<%= index %>">
                                    <img src="<%= img %>" alt="Фото <%= index + 1 %>" style="width: 100px; height: 100px; object-fit: cover; border-radius: 8px; border: 2px solid #dee2e6;">
                                    <button type="button" 
                                            class="remove-image-btn" 
                                            data-product-id="<%= product.id %>" 
                                            data-index="<%= index %>"
                                            style="position: absolute; top: -8px; right: -8px; background: #dc3545; color: #fff; border: none; border-radius: 50%; width: 24px; height: 24px; cursor: pointer; font-size: 14px; line-height: 24px; text-align: center; font-weight: bold;">×</button>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                <% } %>
                
                <!-- Загрузка новых изображений -->
                <input type="file" id="images" name="images" accept="image/*" multiple>
                <small>Допустимые форматы: JPEG, PNG, GIF, WEBP (макс. 5MB каждый)</small>
                <div id="imagePreview" style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 12px;"></div>
            </div>
            
            <div class="form-group checkbox-group">
                <label>
                    <input type="checkbox" name="is_new" <%= product && product.is_new ? 'checked' : '' %>> Новинка
                </label>
                <label>
                    <input type="checkbox" name="is_popular" <%= product && product.is_popular ? 'checked' : '' %>> Популярное
                </label>
            </div>
            
            <button type="submit" class="btn btn-primary">
                <%= isEdit ? 'Сохранить изменения' : 'Добавить товар' %>
            </button>
        </form>
    </div>
</section>

<script>
// Предпросмотр загружаемых изображений
document.getElementById('images')?.addEventListener('change', function(e) {
    const preview = document.getElementById('imagePreview');
    preview.innerHTML = '';
    
    for (let file of this.files) {
        const reader = new FileReader();
        reader.onload = function(event) {
            const img = document.createElement('img');
            img.src = event.target.result;
            img.style.cssText = 'width: 100px; height: 100px; object-fit: cover; border-radius: 8px; border: 2px solid #dee2e6;';
            preview.appendChild(img);
        };
        reader.readAsDataURL(file);
    }
});

// Удаление изображения через обработчик событий
document.querySelectorAll('.remove-image-btn').forEach(btn => {
    btn.addEventListener('click', async function() {
        const productId = this.dataset.productId;
        const index = this.dataset.index;
        
        if (!confirm('Удалить это изображение?')) return;
        
        try {
            const response = await fetch(`/admin/products/remove-image/${productId}/${index}`, {
                method: 'POST'
            });
            const result = await response.json();
            if (result.success) {
                location.reload();
            } else {
                alert('Ошибка удаления: ' + (result.error || 'Неизвестная ошибка'));
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Ошибка удаления');
        }
    });
});
</script>