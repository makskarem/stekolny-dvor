<section class="catalog-page">
    <div class="container">
        <div class="catalog-layout">
            <!-- Боковая панель с категориями -->
            <aside class="catalog-sidebar">
                <h3>Категории</h3>
                <ul class="category-list">
                    <li>
                        <a href="/catalog" class="<%= !currentCategory ? 'active' : '' %>">Все товары</a>
                    </li>
                    <li>
                        <a href="/catalog?category=novinki"
                            class="<%= currentCategory && currentCategory.slug === 'novinki' ? 'active' : '' %>">🆕
                            Новинки</a>
                    </li>
                    <% if (categories && categories.length> 0) { %>
                        <% categories.forEach(category=> { %>
                            <% if (category.id> 0) { %>
                                <li>
                                    <a href="/catalog?category=<%= category.slug %>"
                                        class="<%= currentCategory && currentCategory.id === category.id ? 'active' : '' %>">
                                        <%= category.name %>
                                    </a>
                                </li>
                                <% } %>
                                    <% }) %>
                                        <% } %>
                </ul>
            </aside>

            <!-- Основной контент -->
            <main class="catalog-main">
                <div class="catalog-header">
                    <h1>
                        <% if (currentCategory && currentCategory.slug==='novinki' ) { %>
                            🆕 Новинки
                            <% } else if (currentCategory && currentCategory.id> 0) { %>
                                <%= currentCategory.name %>
                                    <% } else if (search) { %>
                                        Результаты поиска: "<%= search %>"
                                            <% } else { %>
                                                Все товары
                                                <% } %>
                    </h1>
                    <div class="catalog-controls">
                        <form class="search-form" action="/catalog" method="GET">
                            <input type="text" name="search" placeholder="Поиск товаров..." value="<%= search || '' %>">
                            <button type="submit">Поиск</button>
                        </form>
                    </div>
                </div>

                <div class="products-grid" id="catalogProductsGrid">
                    <% if (products && products.length> 0) { %>
                        <% products.slice(0, 9).forEach(product=> { %>
                            <div class="product-card">
                                <div class="product-image">
                                    <img src="<%= getFirstImage(product) %>" alt="<%= product.name %>">
                                    <% if (product.is_new) { %>
                                        <span class="badge new">Новинка</span>
                                        <% } %>
                                            <% if (product.is_popular) { %>
                                                <span class="badge popular">Популярное</span>
                                                <% } %>
                                </div>
                                <div class="product-info">
                                    <h3>
                                        <%= product.name %>
                                    </h3>
                                    <p class="product-category">
                                        <%= product.category_name || 'Без категории' %>
                                    </p>
                                    <p class="product-volume">
                                        <%= product.volume || '' %>
                                    </p>
                                    <p class="product-price">
                                        <%= product.price %> ₽
                                    </p>
                                    <div class="product-actions">
                                        <a href="/catalog/<%= product.slug %>" class="btn btn-detail">Подробнее</a>
                                        <button class="btn btn-wishlist add-to-wishlist" data-id="<%= product.id %>">❤️
                                            В желаемое</button>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <p class="no-products">Товары не найдены</p>
                                    <% } %>
                </div>

                <% if (products && products.length> 9) { %>
                    <button class="btn-show-more" onclick="showMoreCatalogProducts()">Показать больше</button>
                    <% } %>
            </main>
        </div>
    </div>
</section>

<!-- Передаем данные через data-атрибут -->
<div id="catalogData" style="display:none;" data-products='<%= JSON.stringify(products).replace(/' /g, "&#39;" ) %>'>
</div>

<script>
    const catalogDataElement = document.getElementById('catalogData');
    const allCatalogProducts = catalogDataElement ? JSON.parse(catalogDataElement.dataset.products) : [];
    let catalogProductsShown = 9;

    // Функция для получения первого изображения на клиенте
    function getFirstImageClient(product) {
        if (!product) return '/images/placeholder.jpg';
        
        // Проверяем поле images (это может быть строка JSON или массив)
        if (product.images) {
            try {
                // Если это строка - парсим
                const images = typeof product.images === 'string' 
                    ? JSON.parse(product.images) 
                    : product.images;
                
                if (Array.isArray(images) && images.length > 0) {
                    return images[0];
                }
            } catch(e) {
                console.log('Ошибка парсинга images:', e);
            }
        }
        
        // Если есть image_url (старое поле)
        if (product.image_url) {
            return product.image_url;
        }
        
        return '/images/placeholder.jpg';
    }

    function showMoreCatalogProducts() {
    var grid = document.getElementById('catalogProductsGrid');
    var hidden = allCatalogProducts.slice(catalogProductsShown, catalogProductsShown + 9);
    
    if (hidden.length === 0) {
        var btn = document.querySelector('.btn-show-more');
        if (btn) btn.style.display = 'none';
        return;
    }
    
    // Просто добавляем товары - БЕЗ ВСЯКОЙ ПРОКРУТКИ
    hidden.forEach(function(product) {
        var card = document.createElement('div');
        card.className = 'product-card';
        card.innerHTML = `
            <div class="product-image">
                <img src="${getFirstImageClient(product)}" alt="${product.name}">
                ${product.is_new ? '<span class="badge new">Новинка</span>' : ''}
                ${product.is_popular ? '<span class="badge popular">Популярное</span>' : ''}
            </div>
            <div class="product-info">
                <h3>${product.name}</h3>
                <p class="product-category">${product.category_name || 'Без категории'}</p>
                <p class="product-volume">${product.volume || ''}</p>
                <p class="product-price">${product.price} ₽</p>
                <div class="product-actions">
                    <a href="/catalog/${product.slug}" class="btn btn-detail">Подробнее</a>
                    <button class="btn btn-wishlist add-to-wishlist" data-id="${product.id}">❤️ В желаемое</button>
                </div>
            </div>
        `;
        grid.appendChild(card);
    });
    
    catalogProductsShown += hidden.length;
    
    if (catalogProductsShown >= allCatalogProducts.length) {
        var btn = document.querySelector('.btn-show-more');
        if (btn) btn.style.display = 'none';
    }
    
    // НИКАКОЙ ПРОКРУТКИ - просто инициализируем новые кнопки
    document.querySelectorAll('.add-to-wishlist').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var productId = this.dataset.id;
            if (productId) {
                addToWishlist(productId);
            }
        });
    });
}
</script>